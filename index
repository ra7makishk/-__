    .question-a { display: block !important; }
    body { background: white; }
  }
</style>

<script>
  function downloadPDF() {
    // Open all questions before printing
    document.querySelectorAll('.question').forEach(q => q.classList.add('open'));
    
    const btn = document.querySelector('.pdf-btn');
    btn.style.display = 'none';

    window.print();

    // Restore after print dialog
    setTimeout(() => {
      btn.style.display = 'flex';
    }, 1000);
  }
</script>
